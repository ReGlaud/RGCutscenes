{
	"schemaVersion": 1,
	"id": "rgcutscene",
	"version": "${version}",
	"name": "RGCutscene",
	"description": "This mod will help you create your own cutscenes.",
	"authors": [
		"ReGlaud"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/rgcutscene/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"reglaud.cutscene.RGCutscene"
		],
		"client": [
			"reglaud.cutscene.client.RGCutsceneClient"
		]
	},
	"mixins": [
		"rgcutscene.mixins.json",
		{
			"config": "rgcutscene.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}